{{ $hasGUI := promptBoolOnce . "hasGUI" "Does this machine have a GUI" }}
{{ $isHome := promptBoolOnce . "isHome" "Does this machine in home" }}
{{ $emailHome := "tima.sitnikov@mail.ru" }}
{{ $emailWork := "t.sitnikov@infocom-s.ru" }}

encryption = "age"
[age]
    identity = "~/.config/chezmoi/key.txt"
    recipient = "age1am8j03dq5fmd97y78hzyuulnja9uraxm29zmzheyjf8mpqmq9vdspar3hg"

[data]
# machine
hasGUI = {{ $hasGUI }}
isHome = {{ $isHome }}
# fotn
font_family = "FiraCode Nerd Font Custom"
font_size = 10
font_size_rofi = 14
font_size_notyfication = 12
# theme
icon_theme = "Papirus"
catppuccin_flavor = "mocha"
catppuccin_accent = "mauve"
catppuccin_flavor_up = "Mocha"
catppuccin_accent_up = "Mauve"
# identety
emailHome = {{ $emailHome | quote }}
emailWork = {{ $emailWork | quote }}
email = {{ (ternary $emailHome $emailWork $isHome) | quote }}
# browser
zen_install_path = "/app/zen"
zen_profile = "timofey.Default (release)"

[diff]
    pager = "delta"
[[textconv]]
    pattern = "**/*.json"
    command = "yq"
    args = ["--prettyPrint", "--indent", "4", "--input-format", "json", "--output-format", "json"]
