# ===== Identity =====
# Дефолт (переопределяется через includeIf ниже)
{{ if .isHome -}}
[include]
    path = {{ .chezmoi.homeDir }}/.config/git/config_personal
{{ else -}}
[include]
    path = {{ .chezmoi.homeDir }}/.config/git/config_work
{{ end -}}

# Контекстные оверрайды по директории
[includeIf "gitdir:{{ .chezmoi.homeDir }}/gits/"]
    path = {{ .chezmoi.homeDir }}/.config/git/config_personal

[includeIf "gitdir:{{ .chezmoi.homeDir }}/wgits/"]
    path = {{ .chezmoi.homeDir }}/.config/git/config_work

[user]
    name = Sitnikov Timofey
    email = {{ .email }}

# ===== Signing =====
[commit]
    gpgsign = true

[tag]
    gpgsign = true

[gpg]
    format = ssh

[gpg "ssh"]
    allowedSignersFile = {{ .chezmoi.homeDir }}/.config/git/allowed-signers

[log]
    showSignature = true

# ===== Core behaviour =====
[core]
    editor = hx
    pager = delta --dark --diff-so-fancy
    attributesfile = {{ .chezmoi.homeDir }}/.config/git/attributes

[init]
    defaultBranch = master

[pull]
    rebase = true

[merge]
    conflictstyle = zdiff3

# ===== Credentials =====
[credential]
    helper = store

[credential "https://github.com"]
    helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential

# ===== LFS =====
[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process

# ===== Delta =====
[interactive]
    diffFilter = delta --color-only

[delta]
    features = catppuccin-mocha
    syntax-theme = Catppuccin Mocha
    navigate = true
    dark = true
    light = false
    side-by-side = true

[include]
    path = {{ .chezmoi.homeDir }}/.config/git/catppuccin.gitconfig

# ===== Diff drivers =====
[diff "json-pretty"]
    textconv = json-pretty
    prompt = false

[diff "age-decrypt"]
    textconv = age-decrypt

[diff "age-decrypt-json"]
    textconv = age-decrypt-json

# ===== Aliases =====
[alias]
    dlog = -c diff.external=difft log --ext-diff
    dshow = -c diff.external=difft show --ext-diff
    ddiff = -c diff.external=difft diff
    sl = log --graph --pretty="%Cgreen%aN %C(yellow)Hash %h %C(blue)Date %ad (%C(cyan)%cr%Cblue)%n%C(magenta)Message %Creset%s%n%b" --date=human

# ===== Safety =====
[safe]
    directory = *
