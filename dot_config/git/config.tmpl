[includeIf "gitdir:{{ .chezmoi.homeDir }}/wgits/"]
    path = {{ .chezmoi.homeDir }}/.config/git/config_work

[includeIf "gitdir:{{ .chezmoi.homeDir }}/gits/"]
    path = {{ .chezmoi.homeDir }}/.config/git/config_personal

[core]
    editor = hx
    pager = delta --dark --diff-so-fancy

[user]
    email = {{ .email }}
    name = Sitnikov Timofey

# Signing
[gpg]
    format = ssh
[gpg "ssh"]
	allowedSignersFile = {{ .chezmoi.homeDir }}/.config/git/allowed-signers

[commit]
    gpgsign = true

[log]
	showSignature = true

[tag]
	gpgsign = true
###

[pull]
    rebase = true

# Credential
[credential]
	helper = store

[credential "https://github.com"]
    helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
    helper = !/home/linuxbrew/.linuxbrew/bin/gh auth git-credential
###

[init]
    defaultBranch = master

[merge]
    conflictstyle = zdiff3

[filter "lfs"]
    required = true
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process

# Delta
[interactive]
    diffFilter = delta --color-only

[include]
    path = {{ .chezmoi.homeDir }}/.config/git/catppuccin.gitconfig

[delta]
    features = catppuccin-mocha
    syntax-theme = Catppuccin Mocha
    navigate = true
    dark = true
    light = false
    side-by-side = true
###

[safe]
    directory = *

[alias]
    # Difftastic
    dlog = -c diff.external=difft log --ext-diff
    dshow = -c diff.external=difft show --ext-diff
    ddiff = -c diff.external=difft diff
    ###
    sl = log --graph --pretty=\"%Cgreen%aN %C(yellow)Hash %h %C(blue)Date %ad (%C(cyan)%cr%Cblue)%n%C(magenta)Message %Creset%s%n%b\" --date=human

