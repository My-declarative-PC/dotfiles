@import url("zen-browser/themes/Mocha/Mauve/userChrome.css");

/* Шрифт всего UI Firefox */
* {
    font-family:
        "{{ .font_family }}",
        "Font Awesome 5 Free",
        "Font Awesome 6 Free",
        "Material Icons",
        "Material Symbols Outlined",
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        Roboto,
        Arial,
        Helvetica,
        sans-serif;
    font-feature-settings:
        "cv06",
        "cv14",
        "cv25",
        "cv26",
        "cv27",
        "cv30",
        "cv32",
        "ss04",
        "ss06",
        "ss09",
        "ss10"
        !important;
}
