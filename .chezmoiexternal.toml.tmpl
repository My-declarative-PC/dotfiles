# Catppuccin Themes ################################################################################
[".config/zellij/themes/catppuccin.kdl"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/zellij/refs/heads/main/catppuccin.kdl"
    refreshPeriod = "168h"

[".profile.d/fzf-theme.sh"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/fzf/refs/heads/main/themes/catppuccin-fzf-{{ .catppuccin_flavor }}.sh"
    refreshPeriod = "168h"

[".config/btop/themes/catppuccin_{{ .catppuccin_flavor }}.theme"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/btop/refs/heads/main/themes/catppuccin_{{ .catppuccin_flavor }}.theme"
    refreshPeriod = "168h"

[".config/bat/themes/Catppuccin {{ .catppuccin_flavor_up }}.tmTheme"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/bat/refs/heads/main/themes/Catppuccin%20{{ .catppuccin_flavor_up }}.tmTheme"
    refreshPeriod = "168h"

[".config/git/catppuccin.gitconfig"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/delta/refs/heads/main/catppuccin.gitconfig"
    refreshPeriod = "168h"

[".config/atuin/themes/catppuccin-{{ .catppuccin_flavor }}-{{ .catppuccin_accent }}.toml"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/atuin/refs/heads/main/themes/{{ .catppuccin_flavor }}/catppuccin-{{ .catppuccin_flavor }}-{{ .catppuccin_accent }}.toml"
    refreshPeriod = "168h"

{{- if .hasGUI }}
[".local/share/icons"]
    type = "archive"
    url = "https://github.com/catppuccin/cursors/releases/latest/download/catppuccin-{{ .catppuccin_flavor }}-{{ .catppuccin_accent }}-cursors.zip"
    refreshPeriod = "744h"

[".local/share/themes"]
    type = "archive"
    url = "https://github.com/catppuccin/gtk/releases/latest/download/catppuccin-{{ .catppuccin_flavor }}-{{ .catppuccin_accent }}-standard+default.zip"
    refreshPeriod = "744h"

[".var/app/com.obsproject.Studio/config/obs-studio"]
    type = "archive"
    url = "https://github.com/catppuccin/obs/archive/refs/heads/main.zip"
    refreshPeriod = "744h"
    stripComponents = 1
    include = ["*/themes/*"]

[".config/joplin-desktop/userchrome-main.css"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/joplin/refs/heads/main/src/{{ .catppuccin_flavor }}/userchrome.css"
    refreshPeriod = "744h"
[".config/joplin-desktop/userstyle-main.css"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/joplin/refs/heads/main/src/{{ .catppuccin_flavor }}/userstyle.css"
    refreshPeriod = "744h"

[".config/qt5ct/colors/catppuccin-mocha-mauve.conf"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/qt5ct/refs/heads/main/themes/catppuccin-mocha-mauve.conf"
    refreshPeriod = "168h"
[".config/qt6ct/colors/catppuccin-mocha-mauve.conf"]
    type = "file"
    url = "https://raw.githubusercontent.com/catppuccin/qt5ct/refs/heads/main/themes/catppuccin-mocha-mauve.conf"
    refreshPeriod = "168h"
# end ##############################################################################################

# Fonts ############################################################################################
[".local/share/fonts/fira-code"]
    type = "archive"
    url = "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraCode.zip"
    exact = false
    refreshPeriod = "744h"
    include = ["**/*.ttf"]

[".local/share/fonts/FontAwesome"]
    type = "archive"
    url = "https://use.fontawesome.com/releases/v7.0.0/fontawesome-free-7.0.0-desktop.zip"
    stripComponents = 2
    refreshPeriod = "744h"
    include = ["**/*.otf"]
[".local/share/fonts/FontAwesomeLTS"]
    type = "archive"
    url = "https://use.fontawesome.com/releases/v5.15.4/fontawesome-free-5.15.4-desktop.zip"
    stripComponents = 2
    refreshPeriod = "744h"
    include = ["**/*.otf"]
{{- end }}

{{- if (env "TERMUX_VERSION") }}
[".termux/font.ttf"]
    type = "archive-file"
    url = '{{ gitHubLatestRelease "ryanoasis/nerd-fonts" | toJson | fromJson | jq ".assets[] | select(.name == \"FiraCode.tar.xz\") | .browser_download_url" | first }}'
    path = "FiraCodeNerdFontMono-Regular.ttf"
    refreshPeriod = "744h"
{{- end }}
{{- if .hasGUI }}
# end ##############################################################################################

# Wallpaper ########################################################################################
[".wallpaper"]
    type = "file"
    {{- if .isHome }}
    url = "https://thumb.cloud.mail.ru/weblink/thumb/xw1/PEKf/k73tmyLZd/Rainy%20cyberpunk%20city%20at%20night.png?mt=1775576532000"
    {{- else }}
    url = "https://thumb.cloud.mail.ru/weblink/thumb/xw1/PEKf/k73tmyLZd/Cyberpunk%20cityscape%20under%20rainy%20night%20sky.png?mt=1775576532000"
    {{- end }}
    refreshPeriod = "744h"
{{- end }}
# end ##############################################################################################

# Utils ############################################################################################
[".local/bin/greenclip"]
    type = "file"
    executable = true
    url = "https://github.com/erebe/greenclip/releases/latest/download/greenclip"
    refreshPeriod = "744h"

[".local/bin/batctl"]
    type = "archive-file"
    executable = true
    url = '{{ gitHubLatestRelease "Ooooze/batctl" | toJson | fromJson | jq ".assets[] | select(.name | ascii_downcase | contains(\"linux-x86_64\")) | .browser_download_url" | first}}'
    refreshPeriod = "744h"
    path = "batctl"

[".local/bin/netwatch"]
    type = "archive-file"
    executable = true
    url = '{{ gitHubLatestRelease "matthart1983/netwatch" | toJson | fromJson | jq ".assets[] | select(.name | ascii_downcase | contains(\"linux-x86_64-static\")) | .browser_download_url" | first}}'
    refreshPeriod = "744h"
    path = "netwatch-linux-x86_64-static"

[".local/bin/caligula"]
    type = "file"
    executable = true
    url = "https://github.com/ifd3f/caligula/releases/latest/download/caligula-x86_64-linux"
    refreshPeriod = "744h"

{{- if .hasGUI }}
[".local/bin/ronema"]
    type = "file"
    executable = true
    url = "https://raw.githubusercontent.com/P3rf/rofi-network-manager/refs/heads/master/src/ronema"
    refreshPeriod = "744h"
{{- end }}

## Bluetooth
[".local/bin/bluetui"]
    type = "file"
    executable = true
    url = "https://github.com/pythops/bluetui/releases/latest/download/bluetui-x86_64-linux-musl"
    refreshPeriod = "744h"

[".local/bin/bluetuith"]
    type = "archive-file"
    executable = true
    url = '{{ gitHubLatestRelease "bluetuith-org/bluetuith" | toJson | fromJson | jq ".assets[] | select(.name | ascii_downcase | contains(\"linux_x86\")) | .browser_download_url" | first}}'
    refreshPeriod = "744h"
    path = "bluetuith"
# end ##############################################################################################
